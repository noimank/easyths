# ==============================================
# QuantTrader Environment Configuration
# ==============================================
# Copy this file to .env and update the values
# ==============================================

# Application Configuration
APP_NAME="同花顺交易自动化"
APP_VERSION="1.0.0"

#自己训练的验证码识别模型目录，目录下必须有captcha_ocr.onnx和captcha_ocr.onnx.data
APP_ONNX_MODEL_DIR=""

# 是否保存识别错误的验证码图片，图片保存在 C:\Users\你的用户名\easyths\captcha_error\目录下，收集好之后，重命名为：{验证码}_{uuid}.png, 发送到邮箱noimank@163.com
# 收集的数据将对改进验证码模型非常有帮助，欢迎大家上传数据集！
# 不参与改进请修改为false
APP_SAVE_ERROR_CAPTCHA_IMAGE=true

# Trading Configuration
TRADING_APP_PATH="C:/同花顺远航版/transaction/xiadan.exe"

# Queue Configuration
QUEUE_MAX_SIZE=1000
QUEUE_PRIORITY_LEVELS=5
QUEUE_BATCH_SIZE=10

# API Configuration
API_HOST="0.0.0.0"
API_PORT=7648
API_RATE_LIMIT=100
# MCP服务器传输类型: http, streamable-http, sse
API_MCP_SERVER_TYPE="streamable-http"
# CORS允许的源 - *表示允许所有，逗号分隔多个源，如: http://localhost:3000,https://example.com
API_CORS_ORIGINS="*"
# API密钥 - 可以不设置，设置之后所有API请求都需要在Header中提供: Authorization: Bearer <API_KEY>
API_KEY=
# IP白名单 - 留空表示允许所有IP，逗号分隔多个IP，支持通配符*，如: 127.0.0.1,192.168.1.*
API_IP_WHITELIST=

# Logging Configuration
LOGGING_LEVEL="INFO"

#默认在："C:/Users/你的用户名/easyths/log.txt"
LOGGING_FILE=

